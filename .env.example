# ================================================================
# FLUXY — Variáveis de Ambiente (EXEMPLO)
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA coloque chaves reais neste arquivo — ele é versionado no git.
# ================================================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Service role — somente no servidor (NUNCA expor no client).
# Necessária para criar/excluir usuários via Admin API.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
